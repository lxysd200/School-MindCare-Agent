LLM_BACKEND=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT=20
LLM_TEMPERATURE=0.3

# Optional agent-specific overrides
SUPERVISOR_LLM_TEMPERATURE=0.1
SUPERVISOR_DEEPSEEK_MODEL=deepseek-chat
MEMORY_LLM_TEMPERATURE=0.2
MEMORY_LLM_TIMEOUT=15
COUNSELOR_LLM_TEMPERATURE=0.7
