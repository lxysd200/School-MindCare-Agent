LLM_BACKEND=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT=20
LLM_TEMPERATURE=0.3

# Optional agent-specific overrides
SUPERVISOR_LLM_TEMPERATURE=0.1
SUPERVISOR_DEEPSEEK_MODEL=deepseek-chat
MEMORY_LLM_TEMPERATURE=0.2
MEMORY_LLM_TIMEOUT=15
COUNSELOR_LLM_TEMPERATURE=0.7

# MySQL / SQLAlchemy
# You can either set DATABASE_URL directly,
# or configure MYSQL_HOST / MYSQL_PORT / MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE.
DATABASE_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=mindbridge

# Chroma vector store
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=knowledge_chunks
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
